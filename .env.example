# Application
APP_ENV=dev
APP_NAME=local-delivery
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=delivery_user
POSTGRES_PASSWORD=delivery_pass
POSTGRES_DB=local_delivery
DATABASE_URL=postgresql+asyncpg://delivery_user:delivery_pass@postgres:5432/local_delivery
# In prod, point to read replica:
READ_DATABASE_URL=postgresql+asyncpg://delivery_user:delivery_pass@postgres:5432/local_delivery

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_AVAILABILITY_TTL=60

# Security
JWT_SECRET_KEY=change-this-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
